# Proveedor LLM
# LLM_PROVIDER=mock  -> sin costo ni red (fixtures deterministas). Ideal para dev/demo.
# LLM_PROVIDER=anthropic -> llamadas reales a Claude (requiere ANTHROPIC_API_KEY).
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL_REPORT=claude-haiku-4-5-20251001  # reporte con haiku: rápido, entra en el timeout de 60s de Vercel (sonnet = mejor calidad pero más lento)
LLM_MODEL_LIGHT=claude-haiku-4-5-20251001  # modelo chico para alertas/Q&A

# ASR / Whisper
# ASR_PROVIDER=mock  -> texto canónico, sin descargar el modelo (tests/dev).
# ASR_PROVIDER=faster_whisper -> transcripción real.
ASR_PROVIDER=faster_whisper
WHISPER_MODEL=tiny          # tiny | base | small | medium | large-v3 — "tiny" es el único que entra en los 512MB del free tier de Render (subir solo con más RAM)
WHISPER_DEVICE=cpu          # cpu | cuda
WHISPER_COMPUTE_TYPE=int8

# Telegram
TELEGRAM_BOT_TOKEN=

# Almacenamiento
# STORAGE_BACKEND=sqlite   -> SQLite + Chroma en disco (default; cero infra, ideal para tests o backend solo).
# STORAGE_BACKEND=postgres -> Supabase/Postgres + pgvector (lo que usa prod; y para dev full-stack contra Supabase local).
STORAGE_BACKEND=sqlite

# Rutas locales (solo aplican si STORAGE_BACKEND=sqlite):
DB_PATH=./data/reports.db
CHROMA_PATH=./data/chroma

# Connection string de Postgres (solo si STORAGE_BACKEND=postgres).
# Dev contra Supabase local:  postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Prod: Session pooler de Supabase + ?sslmode=require (el valor real vive en el dashboard, NO acá).
DATABASE_URL=

# CORS — orígenes web permitidos para el navegador (separados por coma).
# Dev: el default ya cubre localhost (http://localhost:3000,http://127.0.0.1:3000).
# Prod: DEBE incluir el dominio del web app en Vercel, o el navegador queda bloqueado por CORS.
CUIDAVOZ_WEB_ORIGINS=

# Auth server-to-server (IMPORTANTE en prod): token compartido que el web app
# manda en el header X-Internal-Token. La API usa el service role (bypassa RLS),
# así que sin este token queda expuesta a cualquiera que conozca un elder_id.
# Generá uno fuerte (ej. `openssl rand -hex 32`) y poné EL MISMO valor en la env
# CUIDAVOZ_INTERNAL_TOKEN del web app. Si queda vacío, la API arranca en modo
# abierto (con warning) — solo aceptable en dev local.
INTERNAL_API_TOKEN=
