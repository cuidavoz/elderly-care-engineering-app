# Variables de entorno de CuidaVoz (web)
# Copiá este archivo a `.env.local` y completá con los valores reales.
#
# Los valores reales de desarrollo salen de `npx supabase start`
# (lo provee el módulo de Supabase del repo). Ese comando imprime la
# API URL y la anon key del stack local.

# URL del proyecto Supabase (local: http://127.0.0.1:54321)
NEXT_PUBLIC_SUPABASE_URL=

# Anon / publishable key del proyecto Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL del backend Python (FastAPI) de CuidaVoz. Solo server-side: los
# Route Handlers la usan para proxyear audio (/reportes) y consultas
# (/consultas). Sin NEXT_PUBLIC_ a propósito (no debe exponerse al browser).
# Default si falta: http://localhost:8000
CUIDAVOZ_API_BASE=http://localhost:8000

# Token compartido server-to-server hacia el backend Python. Debe ser EL MISMO
# valor que INTERNAL_API_TOKEN del backend. Solo server-side (sin NEXT_PUBLIC_).
# Sin esto, el backend (que usa service role) queda expuesto a accesos directos.
CUIDAVOZ_INTERNAL_TOKEN=

# URL pública del sitio. Se usa para armar links absolutos en los mails de
# invitación y en el redirect de confirmación de cuenta.
#   - Local: http://localhost:3000
#   - Producción (Vercel): https://elderly-care-engineering-app-gold.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- SMTP (envío de mails de invitación) ---
# Cuenta de Gmail compartida + App Password (NO la contraseña normal de la cuenta;
# se genera en https://myaccount.google.com/apppasswords con 2FA activado).
# Sin estas vars, la app no manda mails pero la invitación se crea igual (link
# copiable). Los mismos datos van además en Supabase → Auth → SMTP Settings, para
# que también lleguen los mails de confirmación de cuenta.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=cuidavoz.team@gmail.com
SMTP_PASS=
SMTP_FROM=CuidaVoz <cuidavoz.team@gmail.com>
